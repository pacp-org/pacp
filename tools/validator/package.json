{
  "name": "pacp-validator",
  "version": "1.0.0",
  "description": "CLI minima para validar arquivos PACP",
  "main": "dist/cli.js",
  "bin": {
    "pacp-validate": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "validate": "node dist/cli.js",
    "validate:examples": "npm run build && node dist/validate-examples.js",
    "sync:product-refs": "npm run build && node dist/sync-product-refs.js"
  },
  "keywords": [
    "pacp",
    "validator",
    "json-schema",
    "pricing"
  ],
  "author": "PACP contributors",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "typescript": "^5.9.3"
  }
}
